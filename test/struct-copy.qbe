export data $x = align 4 { w 123, z 12 }
export
function w $main() {
@start.1
	%.1 =l alloc4 16
@body.2
	%.2 =w loadw $x
	storew %.2, %.1
	%.3 =l add $x, 4
	%.4 =l add %.1, 4
	%.5 =w loadw %.3
	storew %.5, %.4
	%.6 =l add %.3, 4
	%.7 =l add %.4, 4
	%.8 =w loadw %.6
	storew %.8, %.7
	%.9 =l add %.6, 4
	%.10 =l add %.7, 4
	%.11 =w loadw %.9
	storew %.11, %.10
	%.12 =l add %.1, 0
	%.13 =w loadw %.12
	%.14 =w cnew %.13, 123
	ret %.14
}
