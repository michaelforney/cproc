export
function w $main() {
@start.1
	%.1 =l alloc4 4
	%.2 =l alloc8 8
	%.5 =l alloc4 4
@body.2
	storew 0, %.1
	%.3 =w loadw %.1
	jnz %.3, @cond_true.3, @cond_false.4
@cond_true.3
	%.4 =l extsw 0
	jmp @cond_join.5
@cond_false.4
	%.6 =w loadw %.1
	storew %.6, %.5
@cond_join.5
	%.7 =l phi @cond_true.3 %.4, @cond_false.4 %.5
	storel %.7, %.2
	%.8 =l loadl %.2
	%.9 =w loadw %.8
	ret %.9
}
