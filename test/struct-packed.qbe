export data $s = align 1 { b 1, l 2, h 3, }
export
function w $main() {
@start.1
@body.2
	%.1 =l add extern $s, 0
	%.2 =w loadsb %.1
	%.3 =l extsb %.2
	%.4 =l add extern $s, 1
	%.5 =l loadl %.4
	%.6 =l add %.3, %.5
	%.7 =l add extern $s, 9
	%.8 =w loadsh %.7
	%.9 =l extsh %.8
	%.10 =l sub %.6, %.9
	ret %.10
}
